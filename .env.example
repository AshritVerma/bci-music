# Copy this file to .env and fill in your real keys. .env is gitignored.

# Required for `muse2 perform` (Lyria RealTime music generation).
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Required for the prompt-guard rewrite layer. When Lyria filters a prompt
# (e.g. for naming a specific artist), Claude Opus 4.7 translates the prompt
# into pure sonic descriptors and the layer auto-retries the Lyria session.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
